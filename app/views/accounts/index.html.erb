<p><%= notice %></p>

<h1>Accounts</h1>

<p>
  <%= link_to "New account", new_account_path %>
</p>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Institution</th>
      <th>Type</th>
      <th>Currency</th>
      <th>Opening balance</th>
      <th>Current balance</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @accounts.each do |account| %>
      <tr>
        <td><%= account.name %></td>
        <td><%= account.institution %></td>
        <td><%= account.account_type&.humanize %></td>
        <td><%= account.currency %></td>
        <td><%= number_to_currency(account.opening_balance) %></td>
        <td><%= number_to_currency(account.current_balance) %></td>
        <td><%= link_to "Show", account %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Budgeting Moneylog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Budgeting Moneylog">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav>
      <%= link_to "Dashboard", dashboard_path %> |
      <%= link_to "Transactions", transactions_path %> |
      <%= link_to "Import CSV", import_transactions_path %> |
      <%= link_to "Accounts", accounts_path %> |
      <%= link_to "Categories", categories_path %> |
      <%= link_to "Budgets", budgets_path %>
    </nav>

    <%= yield %>
  </body>
</html>

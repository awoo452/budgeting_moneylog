<p><%= notice %></p>
<p><%= alert %></p>

<h1>Import transactions</h1>

<% if @import_errors.any? %>
  <div>
    <h2>Import issues</h2>
    <ul>
      <% @import_errors.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with url: import_transactions_path, method: :post, multipart: true do |form| %>
  <div>
    <%= form.label :account_id, "Account" %><br>
    <%= form.collection_select :account_id, @accounts, :id, :name, prompt: "Select account" %>
  </div>

  <div>
    <%= form.label :csv_file, "CSV file" %><br>
    <%= form.file_field :csv_file, accept: ".csv,text/csv" %>
  </div>

  <div>
    <%= form.submit "Import" %>
  </div>
<% end %>

<p>
  <%= link_to "Back", transactions_path %>
</p>

<p><%= notice %></p>

<h1>Budget</h1>

<p>
  <strong>Month:</strong>
  <%= @budget.month %>
</p>

<p>
  <strong>Category:</strong>
  <%= @budget.category&.name %>
</p>

<p>
  <strong>Amount:</strong>
  <%= number_to_currency(@budget.amount) %>
</p>

<p>
  <strong>Notes:</strong>
  <%= @budget.notes %>
</p>

<p>
  <%= link_to "Edit", edit_budget_path(@budget) %> |
  <%= link_to "Back", budgets_path %>
</p>

<%= button_to "Delete", @budget, method: :delete, data: { turbo_confirm: "Are you sure?" } %>
